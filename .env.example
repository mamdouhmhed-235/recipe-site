# Frontend
VITE_API_BASE=/api

# Backend
MEALDB_API_BASE=https://www.themealdb.com/api/json/v1
MEALDB_API_KEY=1
PORT=5174

# Local Development
CLIENT_ORIGIN=http://localhost:5173

# ============================================
# VERCEL DEPLOYMENT - NO CONFIGURATION NEEDED!
# ============================================
# The server automatically handles Vercel deployments:
# - Detects VERCEL_URL environment variable (auto-set by Vercel)
# - Allows any *.vercel.app subdomain for preview deployments
# - You only need to set these if you want to override defaults:
#   - MEALDB_API_BASE (defaults to TheMealDB public API)
#   - MEALDB_API_KEY (defaults to 1, the free public key)
